# Application Settings
APP_NAME=Enterprise AI Document Intelligence Platform
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Security
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
ALLOWED_HOSTS=*

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/docai
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL=3600

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# AWS S3 (Optional - set USE_S3_STORAGE=false for local development)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your-bucket-name
AWS_REGION=us-east-1
USE_S3_STORAGE=false

# Gemini API
GEMINI_API_KEY=your_gemini_api_key
USE_GEMINI_FALLBACK=true

# OCR Settings
TESSERACT_PATH=tesseract
OCR_LANGUAGE=eng

# Document Processing
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=.pdf,.jpg,.jpeg,.png,.tiff
ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png,image/tiff

# BERT Model
BERT_MODEL_NAME=bert-base-uncased
BERT_MODEL_PATH=models/bert/document_classifier
NER_MODEL_PATH=models/bert/ner_model
CLASSIFICATION_THRESHOLD=0.7
MAX_SEQUENCE_LENGTH=512

# Fraud Detection
FRAUD_DETECTION_ENABLED=true
ANOMALY_THRESHOLD=2.5
DUPLICATE_SIMILARITY_THRESHOLD=0.95

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Async Processing
ASYNC_PROCESSING=true
MAX_CONCURRENT_TASKS=5